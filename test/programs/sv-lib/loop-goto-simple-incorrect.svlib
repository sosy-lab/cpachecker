(set-logic QF_LIA)
(set-info :format-version 1.0)

(define-proc main () () ((x Int))
  (!
    (sequence
      (assign (x 0))
      (goto N0)
      (assume false)
      (! (label N1) :tag N1)
      (assign (x (+ x 0)))
      (! (label N0) :tag N0)
      (if(< x 3)
        (sequence
          (assign (x (+ x 1)))
          (goto N1)))
      (! (sequence) :tag loop-end :check-true (not (= x 3)))
 ):tag main))

(verify-call main ())
