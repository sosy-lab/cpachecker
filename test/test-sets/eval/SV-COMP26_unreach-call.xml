<?xml version="1.0"?>
<!DOCTYPE benchmark PUBLIC "+//IDN sosy-lab.org//DTD BenchExec benchmark 2.3//EN" "https://www.sosy-lab.org/benchexec/benchmark-2.3.dtd">
<benchmark tool="cpachecker" displayName="CPAchecker" timelimit="15 min" hardtimelimit="16 min" memlimit="15 GB" cpuCores="4">

  <require cpuModel="Intel Xeon E3-1230 v5 @ 3.40 GHz" />

  <option name="--heap" />
  <option name="10000M" />
  <option name="--benchmark" />
  <option name="--timelimit" />
  <option name="900 s" />


  <!-- Used Analysis(es): -->
  <rundefinition name="valueAnalysis-NoCegar">
    <option name="--valueAnalysis-NoCegar" />
  </rundefinition>


  <!-- (Symbolic Execution (based on our Value Analysis. Saves more information in the PersistentMap)) -->
  <rundefinition name="symbolicExecution-NoCegar">
    <option name="--symbolicExecution-NoCegar" />
  </rundefinition>

  <!-- (Symbolic Execution with Abstraction Refinement. This results in more Map modifications compared to regular Symbolic Execution.) -->
  <rundefinition name="symbolicExecution-Cegar">
    <option name="--valueAnalysis-NoCegar" />
  </rundefinition>

  <!-- (Value Analysis with Abstraction Refinement. This results in more Map modifications compared to regular Value Analysis.) -->
  <rundefinition name="valueAnalysis-Cegar">
    <option name="--valueAnalysis-Cegar" />
  </rundefinition>


  <!-- Reachsafety category 2026 -->
  
    <tasks name="C.unreach-call.Arrays">
      <includesfile>../programs/benchmarks/Arrays.set</includesfile>
      <propertyfile>../programs/benchmarks/properties/unreach-call.prp</propertyfile>
    </tasks>
    <tasks name="C.unreach-call.BitVectors">
