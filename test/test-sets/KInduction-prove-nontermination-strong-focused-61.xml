<!DOCTYPE benchmark PUBLIC "+//IDN sosy-lab.org//DTD BenchExec benchmark 2.3//EN" "https://www.sosy-lab.org/benchexec/benchmark-2.3.dtd">
<benchmark tool="cpachecker" displayName="CPAchecker" timelimit="15 min" hardtimelimit="16 min" memlimit="15 GB" cpuCores="2">

  <require cpuModel="Intel Xeon E3-1230 v5 @ 3.40 GHz" />

  <resultfiles>**/witness.*</resultfiles>

  <option name="--KInduction-prove-nontermination-strong" />
  <option name="--heap" />
  <option name="10000M" />
  <option name="--benchmark" />
  <option name="--timelimit" />
  <option name="900s" />

  <!-- 88 programs: 54 currently proved + 7 lost since 2026-05-09 baseline
       + 27 incorrect-false cases from the 2026-05-21 14:41:55 termination run.
       Subset of KInduction-prove-nontermination-strong-svcomp-nontermination.xml
       for fast regression validation. -->
  <rundefinition name="Focused-61">
    <tasks name="C.termination.Focused61">
      <includesfile>../programs/nontermination-strong-local/KInduction-prove-nontermination-strong-focused-61.set</includesfile>
      <propertyfile>../sv-benchmarks/c/properties/termination.prp</propertyfile>
    </tasks>
  </rundefinition>

  <columns>
    <column title="UsedConfig">Used algorithm property</column>
  </columns>
</benchmark>
