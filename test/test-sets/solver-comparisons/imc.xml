<!--
Interpolating Model Checking (IMC) test-set that uses each available solver that support all theories necessary for a sound analysis for SAT checking and Craig-interpolant generation.
This tests each solver for their performance in regards to incremental SAT checking in multiple theories/logics, model retrieval, as well as interpolation.
Yices2 is disabled per default in CPAchecker. To enable Yices2, see comment below.
-->
<!DOCTYPE benchmark PUBLIC "+//IDN sosy-lab.org//DTD BenchExec benchmark 2.3//EN" "https://www.sosy-lab.org/benchexec/benchmark-2.3.dtd">
<benchmark tool="cpachecker" timelimit="900 s" hardtimelimit="1000 s" memlimit="15 GB" cpuCores="4">

  <option name="--heap">10000M</option>
  <option name="--benchmark"/>
   <!-- SV-Comp files assume that malloc always succeeds -->
  <option name="--option">cpa.predicate.memoryAllocationsAlwaysSucceed=true</option>


  <option name="--bmc-interpolation"/>
  <!-- Allow fallback to BMC, as we want to test the analysis -->
  <option name="--option">imc.fallBack=true</option>


  <rundefinition name="mathsat5">
    <option name="--option">solver.solver=mathsat5</option>
  </rundefinition>

  <rundefinition name="cvc5">
    <option name="--option">solver.solver=cvc5</option>
  </rundefinition>

  <rundefinition name="princess">
    <option name="--option">cpa.predicate.encodeFloatAs=UNSUPPORTED</option>
    <option name="--option">solver.solver=princess</option>
  </rundefinition>

  <rundefinition name="bitwuzla">
    <!-- Integer as BV is not impacting soundness -->
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">solver.solver=bitwuzla</option>
  </rundefinition>

  <rundefinition name="z3_with_interpolation">
    <!-- This is a distinct (old) Z3 version compared to solver.solver=Z3 that supports interpolation -->
    <option name="--option">solver.solver=Z3_WITH_INTERPOLATION</option>
  </rundefinition>

  <!-- Add Yices2 w native interpolation and SMTInterpol w bitvector support once JavaSMT 6.0.0+ is available. -->

  <!-- We can also interpolate on a distinct solver to the one checking for satisfiability -->
  <rundefinition name="mathsat5-interpolate_with_cvc5">
    <option name="--option">solver.solver=mathsat5</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

  <rundefinition name="z3-interpolate_with_cvc5">
    <option name="--option">solver.solver=z3</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

  <rundefinition name="cvc4-interpolate_with_cvc5">
    <option name="--option">solver.solver=cvc4</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
    <!-- CVC4 needs a larger stack -->
    <option name="--stack">50M</option>
  </rundefinition>

  <rundefinition name="princess-interpolate_with_cvc5">
    <option name="--option">cpa.predicate.encodeFloatAs=UNSUPPORTED</option>
    <option name="--option">solver.solver=princess</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

  <rundefinition name="bitwuzla-interpolate_with_cvc5">
    <!-- Integer as BV is not impacting soundness -->
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">solver.solver=bitwuzla</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

  <!-- To install Yices2, please edit `lib/ivy.xml` and include the GPL-licensed parts of JavaSMT. -->
  <rundefinition name="yices2-interpolate_with_cvc5">
    <option name="--option">cpa.predicate.encodeFloatAs=UNSUPPORTED</option>
    <option name="--option">solver.solver=yices2</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

  <rundefinition name="z3-interpolate_with_mathsat5">
    <option name="--option">solver.solver=z3</option>
    <option name="--option">solver.interpolationSolver=mathsat5</option>
  </rundefinition>

  <rundefinition name="cvc4-interpolate_with_mathsat5">
    <option name="--option">solver.solver=cvc4</option>
    <option name="--option">solver.interpolationSolver=mathsat5</option>
    <!-- CVC4 needs a larger stack -->
    <option name="--stack">50M</option>
  </rundefinition>

  <rundefinition name="cvc5-interpolate_with_mathsat5">
    <option name="--option">solver.solver=cvc5</option>
    <option name="--option">solver.interpolationSolver=mathsat5</option>
  </rundefinition>

  <rundefinition name="princess-interpolate_with_mathsat5">
    <option name="--option">cpa.predicate.encodeFloatAs=UNSUPPORTED</option>
    <option name="--option">solver.solver=princess</option>
    <option name="--option">solver.interpolationSolver=mathsat5</option>
  </rundefinition>

  <rundefinition name="bitwuzla-interpolate_with_mathsat5">
    <!-- Integer as BV is not impacting soundness -->
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">solver.solver=bitwuzla</option>
    <option name="--option">solver.interpolationSolver=mathsat5</option>
  </rundefinition>

  <!-- To install Yices2, please edit `lib/ivy.xml` and include the GPL-licensed parts of JavaSMT. -->
  <rundefinition name="yices2-interpolate_with_mathsat5">
    <option name="--option">cpa.predicate.encodeFloatAs=UNSUPPORTED</option>
    <option name="--option">solver.solver=yices2</option>
    <option name="--option">solver.interpolationSolver=mathsat5</option>
  </rundefinition>


  <rundefinition name="mathsat5-interpolate_with_bitwuzla">
    <!-- Integer as BV is not impacting soundness and is needed for Bitwuzla -->
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">solver.solver=mathsat5</option>
    <option name="--option">solver.interpolationSolver=bitwuzla</option>
  </rundefinition>

  <rundefinition name="z3-interpolate_with_bitwuzla">
    <!-- Integer as BV is not impacting soundness and is needed for Bitwuzla -->
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">solver.solver=z3</option>
    <option name="--option">solver.interpolationSolver=bitwuzla</option>
  </rundefinition>

  <rundefinition name="cvc4-interpolate_with_bitwuzla">
    <!-- Integer as BV is not impacting soundness and is needed for Bitwuzla -->
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">solver.solver=cvc4</option>
    <option name="--option">solver.interpolationSolver=bitwuzla</option>
    <!-- CVC4 needs a larger stack -->
    <option name="--stack">50M</option>
  </rundefinition>

  <rundefinition name="cvc5-interpolate_with_bitwuzla">
    <!-- Integer as BV is not impacting soundness and is needed for Bitwuzla -->
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">solver.solver=cvc5</option>
    <option name="--option">solver.interpolationSolver=bitwuzla</option>
  </rundefinition>

  <rundefinition name="princess-interpolate_with_bitwuzla">
    <!-- Integer as BV is not impacting soundness and is needed for Bitwuzla -->
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">cpa.predicate.encodeFloatAs=UNSUPPORTED</option>
    <option name="--option">solver.solver=princess</option>
    <option name="--option">solver.interpolationSolver=bitwuzla</option>
  </rundefinition>

  <!-- To install Yices2, please edit `lib/ivy.xml` and include the GPL-licensed parts of JavaSMT. -->
  <rundefinition name="yices2-interpolate_with_bitwuzla">
    <!-- Integer as BV is not impacting soundness and is needed for Bitwuzla -->
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">cpa.predicate.encodeFloatAs=UNSUPPORTED</option>
    <option name="--option">solver.solver=yices2</option>
    <option name="--option">solver.interpolationSolver=bitwuzla</option>
  </rundefinition>
  

  <!-- SV-COMP26 task-set consisting of the ReachSafety category, as well as all unreach-call tasks from Concurrency and SoftwareSystems -->
  <tasks name="C.unreach-call.Arrays">
    <includesfile>../../programs/benchmarks/Arrays.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.BitVectors">
