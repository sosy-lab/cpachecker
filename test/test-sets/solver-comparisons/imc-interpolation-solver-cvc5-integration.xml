<!--
Interpolating Model Checking (IMC) test-set that uses each available solver for SAT checking, but always uses CVC5 as interpolating solver.
This tests each solver for their performance in regards to incremental SAT checking in multiple theories/logics, model retrieval, as well as parsing and dumping of SMTLIB2.
Interpolation is not required by each solver, as satisfiable formulas are dumped to SMTLIB2 and parsed by CVC5, which is then used as interpolating solver.
CVC5s results are then dumped to SMTLIB2 again and parsed by the original solver again.
Yices2 is disabled per default in CPAchecker. To enable Yices2, see comment below.
-->
<!DOCTYPE benchmark PUBLIC "+//IDN sosy-lab.org//DTD BenchExec benchmark 2.3//EN" "https://www.sosy-lab.org/benchexec/benchmark-2.3.dtd">
<benchmark tool="cpachecker" displayName="CPAchecker" timelimit="15 min" hardtimelimit="16 min" memlimit="15 GB" cpuCores="4">

  <!-- Use Apollon by default, override if desired -->
  <require cpuModel="Intel Xeon E3-1230 v5 @ 3.40 GHz" />

  <option name="--heap">13000M</option>
  <!-- CVC4 needs a larger stack -->
  <option name="--stack">50M</option>
  <option name="--no-output-files"/>
  <option name="--benchmark"/>
   <!-- SV-Comp files assume that malloc always succeeds -->
  <option name="--option">cpa.predicate.memoryAllocationsAlwaysSucceed=true</option>


  <option name="--bmc-interpolation"/>
  <!-- Disable fallback to BMC, as we want to test interpolation/parsing/dumping -->
  <option name="--option">imc.fallBack=false</option>


  <rundefinition name="imc-mathsat5-cvc5">
    <option name="--option">solver.solver=mathsat5</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

  <rundefinition name="imc-z3-cvc5">
    <option name="--option">solver.solver=z3</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

  <rundefinition name="imc-cvc4-cvc5">
    <option name="--option">solver.solver=cvc4</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

  <rundefinition name="imc-cvc5-cvc5">
    <option name="--option">solver.solver=cvc5</option>
  </rundefinition>

  <rundefinition name="imc-smtinterpol-cvc5">
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=smtinterpol</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

  <rundefinition name="imc-princess-cvc5">
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=princess</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

    <rundefinition name="imc-opensmt2-cvc5">
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=opensmt</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

  <rundefinition name="imc-boolector-cvc5">
    <option name="--option">cpa.predicate.encodeFloatAs=UNSUPPORTED</option>
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <!-- Pointer aliasing requires visitation, but Boolector does not support visitation -->
    <option name="--option">cpa.predicate.handlePointerAliasing=false</option>
    <!-- No pointer aliasing makes counterexamples imprecise -->
    <option name="--option">counterexample.export.allowImpreciseCounterexamples=true</option>
    <option name="--option">solver.solver=boolector</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

    <rundefinition name="imc-bitwuzla-cvc5">
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">solver.solver=bitwuzla</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>

  <!-- To install Yices2, please edit `lib/ivy.xml` and include the GPL-licensed parts of JavaSMT. -->
  <rundefinition name="imc-yices2-cvc5">
    <option name="--option">cpa.predicate.encodeFloatAs=RATIONAL</option>
    <option name="--option">solver.solver=yices2</option>
    <option name="--option">solver.interpolationSolver=cvc5</option>
  </rundefinition>
  

