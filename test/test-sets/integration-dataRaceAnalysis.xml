<!DOCTYPE benchmark PUBLIC "+//IDN sosy-lab.org//DTD BenchExec benchmark 2.3//EN" "http://www.sosy-lab.org/benchexec/benchmark-2.3.dtd">
<benchmark tool="cpachecker" timelimit="90 s" hardtimelimit="120 s" memlimit="2 GB" cpuCores="2">

  <option name="--no-output-files"/>
  <option name="--heap">1500M</option>
  
  <rundefinition>
    <option name="--dataRaceAnalysis"/>
  </rundefinition>

  <tasks>
    <includesfile>../programs/benchmarks/Concurrency.set</includesfile>
    <propertyfile>../programs/benchmarks/properties/no-data-race.prp</propertyfile>
    <exclude>../programs/benchmarks/pthread-wmm/mix000.opt.yml</exclude> <!-- flapping timeout -->
    <exclude>../programs/benchmarks/pthread-wmm/rfi000_power.oepc_pso.oepc_rmo.oepc.yml</exclude> <!-- flapping timeout -->
    <exclude>../programs/benchmarks/pthread-wmm/rfi008.opt.yml</exclude> <!-- flapping timeout -->
    <exclude>../programs/benchmarks/pthread-wmm/rfi010.yml</exclude> <!-- flapping timeout -->
    <exclude>../programs/benchmarks/pthread-wmm/safe005_tso.yml</exclude> <!-- flapping timeout -->
    <exclude>../programs/benchmarks/pthread-wmm/safe015_pso.oepc_pso.opt_tso.oepc_tso.opt.yml</exclude> <!-- flapping timeout -->
    <exclude>../programs/benchmarks/pthread-wmm/safe032_tso.yml</exclude> <!-- flapping timeout -->
    <exclude>../programs/benchmarks/pthread-wmm/safe034_tso.yml</exclude> <!-- flapping timeout -->
    <exclude>../programs/benchmarks/pthread-wmm/safe037.yml</exclude> <!-- flapping timeout -->
    <exclude>../programs/benchmarks/weaver/chl-name-comparator-subst.wvr.yml</exclude> <!-- flapping error/timeout -->
    <exclude>../programs/benchmarks/weaver/chl-name-comparator-trans.wvr.yml</exclude> <!-- flapping error/timeout -->
    <exclude>../programs/benchmarks/weaver/chl-sre-trans.wvr.yml</exclude> <!-- flapping timeout -->
  </tasks>

</benchmark>
