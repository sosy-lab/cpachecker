<!DOCTYPE benchmark PUBLIC "+//IDN sosy-lab.org//DTD BenchExec benchmark 1.0//EN" "http://www.sosy-lab.org/benchexec/benchmark-1.0.dtd">
<benchmark tool="cpachecker" timelimit="300 s" hardtimelimit="360 s" memlimit="8 GB" cpuCores="2">

  <option name="--benchmark"/>
  <option name="--no-output-files"/>
  <option name="--heap">6000M</option>

  <tasks name="Minepump-Termination">
    <include>../programs/benchmarks/product-lines/minepump_spec2_product31.cil.yml</include>
    <propertyfile>../programs/benchmarks/properties/termination.prp</propertyfile>
  </tasks>

  <rundefinition name="bmc-prove-termination">
    <option name="--config">config/bmc-prove-termination.properties</option>
  </rundefinition>

  <columns>
    <column title="total">time for CPAchecker</column>
    <column title="result">status</column>
  </columns>
</benchmark>
