<!--
Runs Bounded Model Checking (BMC) with three settings; a maximum loop bound of 1, a maximum loop bound of 10, and with automatically incrementing maximum loop bound.
-->
<!DOCTYPE benchmark PUBLIC "+//IDN sosy-lab.org//DTD BenchExec benchmark 2.3//EN" "https://www.sosy-lab.org/benchexec/benchmark-2.3.dtd">
<benchmark tool="cpachecker" timelimit="900 s" hardtimelimit="1000 s" memlimit="15 GB" cpuCores="2">

  <option name="--heap">10000M</option>
  <option name="--benchmark"/>
   <!-- SV-Comp files assume that malloc always succeeds -->
  <option name="--option">cpa.predicate.memoryAllocationsAlwaysSucceed=true</option>

  
  <!-- Bounded Model Checking (BMC) with an automatically incrementing maximum loop bound -->
  <rundefinition name="bmc-incremental">
    <option name="--bmc-incremental"/>
  </rundefinition>


  <!-- Bounded Model Checking (BMC) with a fixed maximum loop bound of 1 -->
  <rundefinition name="bmc-max-loop-bound-1">
    <option name="--bmc"/>
    <option name="--option">cpa.loopbound.maxLoopIterations=1</option>
  </rundefinition>


  <!-- Bounded Model Checking (BMC) with a fixed maximum loop bound of 10 -->
  <rundefinition name="bmc-max-loop-bound-10">
    <option name="--bmc"/>
    <option name="--option">cpa.loopbound.maxLoopIterations=10</option>
  </rundefinition>


  <!-- SV-COMP26 unreach-call benchmark-set -->
  <tasks name="C.unreach-call.Arrays">
    <includesfile>../../programs/benchmarks/Arrays.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.BitVectors">
    <includesfile>../../programs/benchmarks/BitVectors.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.ControlFlow">
    <includesfile>../../programs/benchmarks/ControlFlow.set</includesfile>
    <includesfile>../../programs/benchmarks/Sanity.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.ECA">
    <includesfile>../../programs/benchmarks/ECA.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.Floats">
    <includesfile>../../programs/benchmarks/Floats.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.Heap">
    <includesfile>../../programs/benchmarks/Heap.set</includesfile>
    <includesfile>../../programs/benchmarks/LinkedLists.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.Loops">
    <includesfile>../../programs/benchmarks/Loops.set</includesfile>
    <includesfile>../../programs/benchmarks/VerifyThis-Loops.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.ProductLines">
    <includesfile>../../programs/benchmarks/ProductLines.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.Recursive">
    <includesfile>../../programs/benchmarks/Recursive.set</includesfile>
    <includesfile>../../programs/benchmarks/VerifyThis-Recursive.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.Sequentialized">
    <includesfile>../../programs/benchmarks/Sequentialized.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.XCSP">
    <includesfile>../../programs/benchmarks/XCSP.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
