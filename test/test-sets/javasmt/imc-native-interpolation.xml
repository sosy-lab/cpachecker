<!--
Interpolating Model Checking (IMC) test-set that uses each available solver for SAT checking and Craig-interpolant generation.
This tests each solver for their performance in regards to incremental SAT checking in multiple theories/logics, model retrieval, as well as interpolation.
Yices2 is disabled per default in CPAchecker. To enable Yices2, see comment below.
-->
<!DOCTYPE benchmark PUBLIC "+//IDN sosy-lab.org//DTD BenchExec benchmark 2.3//EN" "https://www.sosy-lab.org/benchexec/benchmark-2.3.dtd">
<benchmark tool="cpachecker" displayName="CPAchecker" timelimit="15 min" hardtimelimit="16 min" memlimit="15 GB" cpuCores="4">

  <!-- Use Apollon by default, override if desired -->
  <require cpuModel="Intel Xeon E3-1230 v5 @ 3.40 GHz" />

  <option name="--heap">13000M</option>
  <option name="--stack" reason="CVC4 needs a larger stack">50M</option>
  <option name="--no-output-files"/>
  <option name="--benchmark"/>
   <!-- SV-Comp files assume that malloc always succeeds -->
  <option name="--option">cpa.predicate.memoryAllocationsAlwaysSucceed=true</option>


  <option name="--bmc-interpolation"/>
  <!-- Disable fallback to BMC, as we want to test interpolation -->
  <option name="--option">imc.fallBack=false</option>


  <rundefinition name="imc-mathsat5">
    <option name="--option">solver.solver=mathsat5</option>
  </rundefinition>

  <rundefinition name="imc-cvc5">
    <option name="--option">solver.solver=cvc5</option>
  </rundefinition>

  <rundefinition name="imc-smtinterpol">
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=smtinterpol</option>
  </rundefinition>

  <rundefinition name="imc-princess">
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=princess</option>
  </rundefinition>

  <rundefinition name="imc-opensmt2">
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=opensmt</option>
  </rundefinition>
  

  <!-- SV-COMP26 unreach-call benchmark-set -->
  <tasks name="C.unreach-call.Arrays">
    <includesfile>../../programs/benchmarks/Arrays.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.BitVectors">
    <includesfile>../../programs/benchmarks/BitVectors.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.ControlFlow">
    <includesfile>../../programs/benchmarks/ControlFlow.set</includesfile>
    <includesfile>../../programs/benchmarks/Sanity.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
  <tasks name="C.unreach-call.ECA">
