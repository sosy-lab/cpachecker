<!--
Symbolic Execution (with and without CEGAR) test-set that uses each available solver for SAT checking.
This tests each solver for their performance in regards to incremental SAT checking in multiple theories/logics, as well as model retrieval.
Yices2 is disabled per default in CPAchecker. To enable Yices2, see comment below.
-->
<!DOCTYPE benchmark PUBLIC "+//IDN sosy-lab.org//DTD BenchExec benchmark 2.3//EN" "https://www.sosy-lab.org/benchexec/benchmark-2.3.dtd">
<benchmark tool="cpachecker" displayName="CPAchecker" timelimit="900s" hardtimelimit="1000s" memlimit="15 GB" cpuCores="4">

  <!-- Use Apollon by default, override if desired -->
  <require cpuModel="Intel Xeon E3-1230 v5 @ 3.40 GHz" />

  <option name="--heap">13000M</option>
  <!-- CVC4 needs a larger stack -->
  <option name="--stack">50M</option>
  <option name="--no-output-files"/>
  <option name="--benchmark"/>

  <!-- SV-Comp files assume that malloc always succeeds (for CEX) -->
  <option name="--option">cpa.predicate.memoryAllocationsAlwaysSucceed=true</option>


  <rundefinition name="Symbolic_Execution_NoCEGAR-mathsat5">
    <option name="--symbolicExecution-NoCegar" />
    <option name="--option">solver.solver=mathsat5</option>
  </rundefinition>

  <rundefinition name="Symbolic_Execution_CEGAR-mathsat5">
    <option name="--symbolicExecution-Cegar" />
    <option name="--option">solver.solver=mathsat5</option>
  </rundefinition>


  <rundefinition name="Symbolic_Execution_NoCEGAR-z3">
    <option name="--symbolicExecution-NoCegar" />
    <option name="--option">solver.solver=z3</option>
  </rundefinition>

  <rundefinition name="Symbolic_Execution_CEGAR-z3">
    <option name="--symbolicExecution-Cegar" />
    <option name="--option">solver.solver=z3</option>
  </rundefinition>


  <rundefinition name="Symbolic_Execution_NoCEGAR-cvc4">
    <option name="--symbolicExecution-NoCegar" />
    <option name="--option">solver.solver=cvc4</option>
  </rundefinition>

  <rundefinition name="Symbolic_Execution_CEGAR-cvc4">
    <option name="--symbolicExecution-Cegar" />
    <option name="--option">solver.solver=cvc4</option>
  </rundefinition>


  <rundefinition name="Symbolic_Execution_NoCEGAR-cvc5">
    <option name="--symbolicExecution-NoCegar" />
    <option name="--option">solver.solver=cvc5</option>
  </rundefinition>

  <rundefinition name="Symbolic_Execution_CEGAR-cvc5">
    <option name="--symbolicExecution-Cegar" />
    <option name="--option">solver.solver=cvc5</option>
  </rundefinition>


  <rundefinition name="Symbolic_Execution_NoCEGAR-smtinterpol">
    <option name="--symbolicExecution-NoCegar" />
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=smtinterpol</option>
  </rundefinition>

  <rundefinition name="Symbolic_Execution_CEGAR-smtinterpol">
    <option name="--symbolicExecution-Cegar" />
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=smtinterpol</option>
  </rundefinition>


  <rundefinition name="Symbolic_Execution_NoCEGAR-princess">
    <option name="--symbolicExecution-NoCegar" />
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=princess</option>
  </rundefinition>

  <rundefinition name="Symbolic_Execution_CEGAR-princess">
    <option name="--symbolicExecution-Cegar" />
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=princess</option>
  </rundefinition>


  <rundefinition name="Symbolic_Execution_NoCEGAR-opensmt2">
    <option name="--symbolicExecution-NoCegar" />
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=opensmt</option>
  </rundefinition>

  <rundefinition name="Symbolic_Execution_CEGAR-opensmt2">
    <option name="--symbolicExecution-Cegar" />
    <option name="--option">cpa.predicate.encodeFloatAs=INTEGER</option>
    <option name="--option">cpa.predicate.encodeBitvectorAs=INTEGER</option>
    <option name="--option">solver.solver=opensmt</option>
  </rundefinition>


  <rundefinition name="Symbolic_Execution_NoCEGAR-boolector">
    <option name="--symbolicExecution-NoCegar" />
    <option name="--option">cpa.predicate.encodeFloatAs=UNSUPPORTED</option>
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">cpa.predicate.handlePointerAliasing=false</option>
    <option name="--option">counterexample.export.allowImpreciseCounterexamples=true</option>
    <option name="--option">solver.solver=boolector</option>
  </rundefinition>

  <rundefinition name="Symbolic_Execution_CEGAR-boolector">
    <option name="--symbolicExecution-Cegar" />
    <option name="--option">cpa.predicate.encodeFloatAs=UNSUPPORTED</option>
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">cpa.predicate.handlePointerAliasing=false</option>
    <option name="--option">counterexample.export.allowImpreciseCounterexamples=true</option>
    <option name="--option">solver.solver=boolector</option>
  </rundefinition>


  <rundefinition name="Symbolic_Execution_NoCEGAR-bitwuzla">
    <option name="--symbolicExecution-NoCegar" />
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">solver.solver=bitwuzla</option>
  </rundefinition>

  <rundefinition name="Symbolic_Execution_CEGAR-bitwuzla">
    <option name="--symbolicExecution-Cegar" />
    <option name="--option">cpa.predicate.encodeIntegerAs=BITVECTOR</option>
    <option name="--option">solver.solver=bitwuzla</option>
  </rundefinition>


  <!-- To install Yices2, please edit `lib/ivy.xml` and include the GPL-licensed parts of JavaSMT. -->
  <rundefinition name="Symbolic_Execution_NoCEGAR-yices2">
    <option name="--symbolicExecution-NoCegar" />
    <option name="--option">cpa.predicate.encodeFloatAs=RATIONAL</option>
    <option name="--option">solver.solver=yices2</option>
  </rundefinition>

  <rundefinition name="Symbolic_Execution_CEGAR-yices2">
    <option name="--symbolicExecution-Cegar" />
    <option name="--option">cpa.predicate.encodeFloatAs=RATIONAL</option>
    <option name="--option">solver.solver=yices2</option>
  </rundefinition>



  <!-- SV-COMP26 unreach-call benchmark-set -->
  <tasks name="C.unreach-call.Arrays">
    <includesfile>../../programs/benchmarks/Arrays.set</includesfile>
    <propertyfile>../../programs/benchmarks/properties/unreach-call.prp</propertyfile>
  </tasks>
